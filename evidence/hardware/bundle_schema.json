{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OPH Hardware Evidence Bundle Manifest",
  "type": "object",
  "required": [
    "bundle_id",
    "status",
    "claim_class",
    "created_utc",
    "modules",
    "controller",
    "task",
    "verifier",
    "artifacts",
    "controls",
    "non_claims"
  ],
  "properties": {
    "bundle_id": {
      "type": "string",
      "description": "Stable public identifier for this evidence bundle."
    },
    "status": {
      "type": "string",
      "enum": ["template", "calibration", "candidate_evidence", "rejected", "superseded"]
    },
    "claim_class": {
      "type": "string",
      "enum": [
        "none",
        "calibration",
        "reproducible_readout_signature",
        "candidate_enrichment",
        "exact_verifier_confirmed_hit"
      ]
    },
    "created_utc": {
      "type": "string"
    },
    "operators": {
      "type": "array",
      "items": { "type": "string" }
    },
    "modules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["module_id", "body_role", "body_hash"],
        "properties": {
          "module_id": { "type": "string" },
          "body_role": {
            "type": "string",
            "enum": ["torus", "echosahedron", "splitmix", "other"]
          },
          "body_hash": { "type": "string" },
          "mesh_path": { "type": "string" },
          "photo_hashes": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "controller": {
      "type": "object",
      "required": ["controller_id", "firmware_hash", "wiring_map_hash"],
      "properties": {
        "controller_id": { "type": "string" },
        "firmware_hash": { "type": "string" },
        "wiring_map_hash": { "type": "string" }
      }
    },
    "task": {
      "type": "object",
      "required": ["task_id", "benchmark", "scorebook_hash"],
      "properties": {
        "task_id": { "type": "string" },
        "benchmark": { "type": "string" },
        "scorebook_hash": { "type": "string" }
      }
    },
    "verifier": {
      "type": "object",
      "required": ["verifier_id", "verifier_hash"],
      "properties": {
        "verifier_id": { "type": "string" },
        "verifier_hash": { "type": "string" },
        "receipt_path": { "type": "string" }
      }
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "controls": {
      "type": "array",
      "items": { "type": "string" }
    },
    "non_claims": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
